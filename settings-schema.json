{
    "modules-header": {
        "type": "header",
        "description": "Modules"
    },
    "show-cpu": {
        "type": "switch",
        "default": true,
        "description": "Show CPU"
    },
    "show-ram": {
        "type": "switch",
        "default": true,
        "description": "Show RAM"
    },
    "show-gpu": {
        "type": "switch",
        "default": true,
        "description": "Show GPU"
    },
    "show-disk": {
        "type": "switch",
        "default": true,
        "description": "Show disk"
    },
    "show-network": {
        "type": "switch",
        "default": true,
        "description": "Show network"
    },
    "show-temperatures": {
        "type": "switch",
        "default": true,
        "description": "Show temperatures"
    },

    "layout-header": {
        "type": "header",
        "description": "Layout"
    },
    "desklet-width": {
        "type": "spinbutton",
        "default": 680,
        "min": 420,
        "max": 1100,
        "step": 10,
        "units": "px",
        "description": "Width"
    },
    "tile-height": {
        "type": "spinbutton",
        "default": 118,
        "min": 82,
        "max": 180,
        "step": 2,
        "units": "px",
        "description": "Tile height"
    },
    "refresh-interval": {
        "type": "combobox",
        "default": 1,
        "description": "Refresh interval",
        "options": {
            "1 s": 1,
            "2 s": 2,
            "5 s": 5,
            "10 s": 10,
            "30 s": 30
        }
    },
    "history-duration": {
        "type": "combobox",
        "default": 120,
        "description": "Graph history duration",
        "options": {
            "30 s": 30,
            "1 min": 60,
            "2 min": 120,
            "5 min": 300,
            "10 min": 600,
            "30 min": 1800
        }
    },

    "targets-header": {
        "type": "header",
        "description": "Targets"
    },
    "network-interface-mode": {
        "type": "combobox",
        "default": "__auto__",
        "description": "Network interface",
        "options": {
            "Automatic (all active interfaces)": "__auto__",
            "All non-loopback interfaces": "__all__",
            "enp7s0": "enp7s0",
            "wlp6s0": "wlp6s0",
            "tailscale0": "tailscale0",
            "Manual entry": "__manual__"
        }
    },
    "network-interface-manual": {
        "type": "entry",
        "default": "",
        "description": "Manual network interface",
        "tooltip": "Used when Network interface is set to Manual entry. Interface names are limited to letters, numbers, dots, underscores, colons, and dashes.",
        "dependency": "network-interface-mode=__manual__"
    },
    "disk-path": {
        "type": "entry",
        "default": "/",
        "description": "Disk target path",
        "tooltip": "Path passed to df, such as /, /home, or a mounted drive."
    },

    "style-header": {
        "type": "header",
        "description": "Style"
    },
    "light-mode": {
        "type": "switch",
        "default": false,
        "description": "Light mode"
    },
    "background-color": {
        "type": "colorchooser",
        "default": "rgb(12,16,20)",
        "description": "Background color"
    },
    "background-opacity": {
        "type": "scale",
        "default": 0.72,
        "min": 0.1,
        "max": 1,
        "step": 0.01,
        "description": "Background opacity"
    },
    "text-color": {
        "type": "colorchooser",
        "default": "rgb(238,242,246)",
        "description": "Text color"
    },
    "grid-line-color": {
        "type": "colorchooser",
        "default": "rgba(255,255,255,0.16)",
        "description": "Grid line color"
    },

    "colors-header": {
        "type": "header",
        "description": "Accent colors"
    },
    "cpu-color": {
        "type": "colorchooser",
        "default": "rgb(76,194,255)",
        "description": "CPU accent"
    },
    "ram-color": {
        "type": "colorchooser",
        "default": "rgb(120,221,137)",
        "description": "RAM accent"
    },
    "gpu-color": {
        "type": "colorchooser",
        "default": "rgb(183,141,255)",
        "description": "GPU accent"
    },
    "disk-color": {
        "type": "colorchooser",
        "default": "rgb(255,196,87)",
        "description": "Disk accent"
    },
    "network-color": {
        "type": "colorchooser",
        "default": "rgb(95,214,201)",
        "description": "Network accent"
    },
    "temperature-color": {
        "type": "colorchooser",
        "default": "rgb(255,121,111)",
        "description": "Temperature accent"
    }
}
